{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["public/assets/**", ".git/**"],
  "overrides": [
    {
      "files": ["**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ],
  "sortImports": {},
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortTailwindcss": {
    "stylesheet": "./src/styles/mixins/tailwind.css"
  }
}
