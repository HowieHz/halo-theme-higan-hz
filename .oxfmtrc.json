{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["src/generated/**", "src/templates/public/assets/**", "docs/.vitepress/generated/**"],
  "jsdoc": {},
  "overrides": [
    {
      "files": ["**/*.jsonc"],
      "options": {
        "trailingComma": "none"
      }
    }
  ],
  "singleAttributePerLine": true,
  "sortImports": {},
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortTailwindcss": {
    "stylesheet": "./src/templates/_runtime/global/styles.css"
  }
}
