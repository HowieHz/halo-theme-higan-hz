{
  "version": "1.66.7",
  "private": true,
  "keywords": [
    "halo",
    "halo-theme"
  ],
  "homepage": "https://howiehz.top/halo-theme-higan-haozi",
  "bugs": {
    "url": "https://github.com/howiehz/halo-theme-higan-hz/issues"
  },
  "license": "MIT",
  "author": {
    "name": "HowieHz",
    "url": "https://github.com/howiehz"
  },
  "maintainers": [
    {
      "name": "HowieHz",
      "url": "https://github.com/howiehz"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/howiehz/halo-theme-higan-hz"
  },
  "type": "module",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=16384 vite build",
    "build:dev": "BUILD_MODE=dev pnpm run build",
    "build:full": "BUILD_MODE=full pnpm run build",
    "build:theme-preview-for-docs": "BUILD_MODE=preview-for-docs pnpm run build",
    "build:tiny": "BUILD_MODE=tiny pnpm run build",
    "docs:build": "pnpm --filter docs build",
    "docs:prepare-assets": "pnpm --filter docs prepare-assets",
    "docs:preview": "pnpm --filter docs preview",
    "docs:watch": "pnpm --filter docs watch",
    "fmt": "pnpm run '/^fmt:/'",
    "fmt:oxfmt": "oxfmt --threads 3 '**/*.{json,jsonc,yaml,md,css,js,ts,html,vue}' '.github/**/*.{yml,js,json}'",
    "generate:theme-css": "node --experimental-strip-types src/scripts/generate-theme-css.ts",
    "lint": "pnpm run '/^lint:/'",
    "lint:autocorrect": "autocorrect --fix",
    "lint:md": "markdownlint --fix '**/*.md' --ignore-path .gitignore",
    "lint:oxlint+eslint": "oxlint --type-aware --fix && eslint --fix",
    "lint:style": "stylelint --fix '**/*.{css,html,vue}' 'docs/.vitepress/**/*.{css,vue}' --ignore-path .gitignore",
    "lint:type-check:docs:vue-tsc": "vue-tsc -b docs/tsconfig.browser.json",
    "lint:type-check:tsgo": "tsgo -b",
    "migrate:oxlint": "pnpm dlx @oxlint/migrate --type-aware --with-nursery && pnpm oxfmt -- --write .oxlintrc.json",
    "prebuild": "pnpm run generate:theme-css && tw-patch extract --css src/templates/_runtime/global/styles.css",
    "preinstall": "npx only-allow pnpm",
    "prelint": "pnpm run docs:prepare-assets",
    "prepare": "husky && tw-patch install",
    "prewatch:vite": "pnpm run prebuild",
    "watch": "pnpm run '/^watch:/'",
    "watch:vite": "NODE_OPTIONS=--max-old-space-size=16384 BUILD_MODE=dev vite build --watch"
  },
  "dependencies": {
    "alpinejs": "^3.15.12",
    "instant.page": "^5.2.0",
    "mermaid": "^11.15.0"
  },
  "devDependencies": {
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/fa": "^1.2.2",
    "@iconify-json/fa-solid": "^1.2.2",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/material-symbols": "^1.2.74",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.83",
    "@iconify-json/typcn": "^1.2.2",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss-mangle/core": "^5.1.4",
    "@tailwindcss-mangle/shared": "^4.1.5",
    "@tailwindcss/vite": "^4.3.0",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.9.1",
    "@typescript-eslint/parser": "^8.59.4",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "autocorrect-node": "^2.14.0",
    "browserslist": "^4.28.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.66.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lightningcss": "^1.32.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "stylelint": "^17.12.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-patch": "^9.3.7",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-sri3": "^2.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.1"
  },
  "browserslist": [
    "defaults",
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 114",
    "Safari >= 16.4"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": "^11.2.2"
  },
  "packageManager": "pnpm@11.2.2"
}
