{
  "version": "1.58.2",
  "private": true,
  "keywords": [
    "halo",
    "halo-theme",
    "halo-theme-higan",
    "halo-theme-higan-haozi",
    "halo-theme-higan-hz",
    "howiehz"
  ],
  "homepage": "https://howiehz.top/halo-theme-higan-haozi",
  "bugs": {
    "url": "https://github.com/howiehz/halo-theme-higan-hz/issues"
  },
  "license": "MIT",
  "author": {
    "name": "HowieHz",
    "url": "https://github.com/howiehz"
  },
  "maintainers": [
    {
      "name": "HowieHz",
      "url": "https://github.com/howiehz"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/howiehz/halo-theme-higan-hz"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run lint:ts-type-check && tw-patch extract && vite build",
    "dev": "pnpm run \"/^dev:/\"",
    "dev:vite": "vite build --watch",
    "docs:build": "pnpm --filter \"docs\" docs:build",
    "docs:dev": "pnpm --filter \"docs\" docs:dev",
    "docs:preview": "pnpm --filter \"docs\" docs:preview",
    "fmt": "pnpm run \"/^fmt:/\"",
    "fmt:oxfmt": "oxfmt --threads 2 \"**/*.{json,jsonc,yaml,md,css,js,ts,html,vue,less}\" \".github/**/*.{yml,js,json}\"",
    "lint": "pnpm run \"/^lint:/\"",
    "lint:autocorrect": "autocorrect --fix",
    "lint:md": "markdownlint --fix \"**/*.md\" --ignore-path .gitignore",
    "lint:oxlint+eslint": "oxlint --type-aware --fix && eslint --fix",
    "lint:style": "stylelint --fix \"**/*.{css,html,vue}\" \"docs/.vitepress/**/*.{css,vue}\" --ignore-path .gitignore",
    "lint:ts-type-check": "tsgo --noEmit",
    "migrate:oxlint": "pnpm dlx @oxlint/migrate --type-aware --with-nursery && pnpm run fmt",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky && tw-patch install"
  },
  "dependencies": {
    "alpinejs": "^3.15.8"
  },
  "devDependencies": {
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/cib": "^1.2.3",
    "@iconify-json/entypo-social": "^1.2.3",
    "@iconify-json/fa": "^1.2.2",
    "@iconify-json/fa-solid": "^1.2.2",
    "@iconify-json/fluent": "^1.2.41",
    "@iconify-json/heroicons-outline": "^1.2.1",
    "@iconify-json/ic": "^1.2.4",
    "@iconify-json/icomoon-free": "^1.2.1",
    "@iconify-json/material-symbols": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/pepicons-pencil": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/ri": "^1.2.10",
    "@iconify-json/simple-icons": "^1.2.74",
    "@iconify-json/tabler": "^1.2.31",
    "@iconify-json/typcn": "^1.2.2",
    "@iconify-json/uil": "^1.2.3",
    "@iconify/tailwind4": "^1.2.3",
    "@tailwindcss/vite": "^4.2.1",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^25.5.0",
    "@types/picomatch": "^4.0.2",
    "@typescript-eslint/parser": "^8.57.1",
    "@typescript/native-preview": "7.0.0-dev.20260317.1",
    "autocorrect-node": "^2.14.0",
    "browserslist": "^4.28.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "less": "^4.6.4",
    "lightningcss": "^1.32.0",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.2.1",
    "tailwindcss-patch": "^8.7.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-tailwindcss-mangle": "^5.1.1",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vite-plugin-compression2": "^2.5.2",
    "vite-plugin-sri3": "^2.0.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "overrides": {
    "vite": "npm:rolldown-vite@^7.3.1"
  },
  "browserslist": [
    "defaults",
    "Chrome >= 111",
    "Edge >= 111",
    "Firefox >= 114",
    "Safari >= 16.4"
  ],
  "packageManager": "pnpm@10.31.0"
}
