{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:build": "vitepress build",
    "docs:preview": "pnpm run docs:build && vitepress preview",
    "docs:watch": "vitepress dev",
    "generate:preview-css": "node --experimental-strip-types .vitepress/scripts/generate-preview-css.ts",
    "predocs:build": "pnpm run prepare:docs-assets",
    "predocs:preview": "pnpm run prepare:docs-assets",
    "predocs:watch": "pnpm run prepare:docs-assets",
    "prepare:docs-assets": "pnpm --dir .. run build:docs-preview && pnpm run generate:preview-css"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@mdit/plugin-footnote": "^0.23.2",
    "@nolebase/vitepress-plugin-highlight-targeted-heading": "^2.18.2",
    "@whyframe/core": "^0.2.0",
    "@whyframe/vue": "^0.2.0",
    "browserslist": "^4.28.2",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.2",
    "vitepress": "2.0.0-alpha.17",
    "vitepress-plugin-pagefind": "^0.4.20",
    "vue": "^3.5.33"
  }
}
