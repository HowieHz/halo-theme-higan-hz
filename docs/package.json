{
  "name": "docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vitepress build",
    "generate:preview-css": "node --experimental-strip-types .vitepress/scripts/generate-preview-css.ts",
    "prebuild": "pnpm run prepare-assets",
    "prepare-assets": "pnpm --dir .. run build:theme-preview-for-docs && pnpm run generate:preview-css",
    "preview": "pnpm run build && vitepress preview",
    "prewatch": "pnpm run prepare-assets",
    "watch": "vitepress dev"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue-chartjs": "^5.3.3"
  },
  "devDependencies": {
    "@mdit/plugin-footnote": "^1.0.1",
    "@nolebase/vitepress-plugin-highlight-targeted-heading": "^2.18.2",
    "@whyframe/core": "^0.2.0",
    "@whyframe/vue": "^0.2.0",
    "browserslist": "^4.28.4",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.2",
    "vitepress": "2.0.0-alpha.18",
    "vitepress-plugin-pagefind": "^0.4.20",
    "vue": "^3.5.39"
  }
}
